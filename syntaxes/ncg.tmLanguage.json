{
  "name": "NCG",
  "scopeName": "source.ncg",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#definitions"
    },
    {
      "include": "#using"
    },
    {
      "include": "#tests"
    },
    {
      "include": "#graphical"
    },
    {
      "include": "#callables"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#colors"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#booleans"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.ncg",
          "match": "//.*$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.ncg",
          "match": "\\b(?:using|func|module|test|graphical)\\b"
        }
      ]
    },
    "definitions": {
      "patterns": [
        {
          "match": "\\b(func|module)\\b\\s+([A-Za-z0-9_]+)",
          "captures": {
            "1": {
              "name": "keyword.control.ncg"
            },
            "2": {
              "name": "entity.name.function.ncg"
            }
          }
        }
      ]
    },
    "using": {
      "patterns": [
        {
          "match": "\\b(using)\\b\\s+([A-Za-z0-9_]+)",
          "captures": {
            "1": {
              "name": "keyword.control.ncg"
            },
            "2": {
              "name": "entity.name.type.ncg"
            }
          }
        }
      ]
    },
    "tests": {
      "patterns": [
        {
          "match": "\\b(test)\\b\\s+([A-Za-z0-9_]+)",
          "captures": {
            "1": {
              "name": "keyword.control.ncg"
            },
            "2": {
              "name": "entity.name.section.ncg"
            }
          }
        }
      ]
    },
    "graphical": {
      "patterns": [
        {
          "match": "\\b(graphical)\\b\\s+([A-Za-z0-9_]+)",
          "captures": {
            "1": {
              "name": "keyword.control.ncg"
            },
            "2": {
              "name": "entity.name.class.ncg"
            }
          }
        }
      ]
    },
    "callables": {
      "patterns": [
        {
          "match": "(:|=)\\s*([A-Za-z0-9_]+)",
          "captures": {
            "1": {
              "name": "keyword.operator.assignment.ncg"
            },
            "2": {
              "name": "support.function.ncg"
            }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.ncg",
          "match": "<-|->|:|="
        }
      ]
    },
    "colors": {
      "patterns": [
        {
          "name": "constant.other.color.rgb-value.ncg",
          "match": "#[0-9A-Fa-f]{6}"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.ncg",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "booleans": {
      "patterns": [
        {
          "name": "constant.language.boolean.ncg",
          "match": "\\b(?:t|f)\\b"
        }
      ]
    }
  }
}
